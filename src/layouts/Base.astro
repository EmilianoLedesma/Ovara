---
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
  activeNav?: string;
}

const { title, description = 'Plataforma educativa sobre reproducción en animales domésticos.', activeNav } = Astro.props;
---

<!doctype html>
<html lang="es">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content={description} />
  <title>{title} | Ovara</title>
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
</head>
<body>

<nav>
  <a class="logo" href="/">
    <div class="logo-mark"></div>
    <span class="logo-name">Ovara</span>
  </a>
  <div class="nav-links">
    <a href="/especies" class={activeNav === 'especies' ? 'active' : ''}>Especies</a>
    <a href="/especies/comparativas" class={activeNav === 'comparativas' ? 'active' : ''}>Comparar</a>
    <a href="/glosario" class={activeNav === 'glosario' ? 'active' : ''}>Glosario</a>
  </div>
  <a href="/especies" class="nav-cta">Explorar</a>
</nav>

<slot />

<footer>
  <a class="footer-logo" href="/">
    <div class="footer-logo-mark"></div>
    <span>Ovara</span>
  </a>
  <p>Material educativo · Reproducción animal</p>
  <div class="footer-links">
    <a href="/especies">Especies</a>
    <a href="/glosario">Glosario</a>
    <a href="/especies/comparativas">Comparativas</a>
  </div>
</footer>

<script>
// Scroll reveal
const io = new IntersectionObserver(entries => {
  entries.forEach(e => {
    if (e.isIntersecting) { e.target.classList.add('visible'); io.unobserve(e.target); }
  });
}, { threshold: 0.08, rootMargin: '0px 0px -40px 0px' });
document.querySelectorAll('.reveal').forEach(el => io.observe(el));

// Nav shadow on scroll
const nav = document.querySelector('nav') as HTMLElement;
window.addEventListener('scroll', () => {
  nav.style.boxShadow = window.scrollY > 20 ? '0 1px 24px rgba(74,45,138,0.10)' : 'none';
}, { passive: true });
</script>

</body>
</html>

<style>
nav {
  display: flex; align-items: center; justify-content: space-between;
  padding: 0 52px; height: 60px;
  background: rgba(250,248,252,0.88);
  backdrop-filter: blur(20px) saturate(180%);
  border-bottom: 1px solid rgba(218,212,200,0.7);
  position: sticky; top: 0; z-index: 100;
  transition: box-shadow 0.3s var(--ease-apple);
  animation: navIn 0.6s var(--ease-apple) forwards;
}
@keyframes navIn {
  from { opacity: 0; transform: translateY(-10px); }
  to   { opacity: 1; transform: translateY(0); }
}
.logo { display: flex; align-items: center; gap: 10px; text-decoration: none; }
.logo-mark {
  width: 28px; height: 28px; border-radius: 8px;
  background: linear-gradient(140deg, var(--lavender), var(--mint));
  box-shadow: var(--shadow);
  transition: transform 0.4s var(--ease-spring);
}
.logo:hover .logo-mark { transform: rotate(-8deg) scale(1.08); }
.logo-name { font-size: 17px; font-weight: 700; color: var(--ink); letter-spacing: -0.5px; }
.nav-links { display: flex; gap: 28px; }
.nav-links a {
  font-size: 15px; font-weight: 500; color: var(--ink-mid); text-decoration: none;
  transition: color 0.2s var(--ease-apple);
}
.nav-links a:hover { color: var(--ink); }
.nav-links a.active { color: var(--lavender); font-weight: 600; }
.nav-cta {
  padding: 8px 20px; border-radius: 1584px;
  background: var(--ink); color: var(--white);
  font-size: 14px; font-weight: 600; text-decoration: none; letter-spacing: -0.2px;
  transition: background 0.25s var(--ease-apple), transform 0.2s var(--ease-spring);
}
.nav-cta:hover { background: var(--lavender); transform: scale(1.04); }

footer {
  padding: 40px 52px; background: var(--cream);
  border-top: 1px solid var(--oat);
  display: flex; align-items: center; justify-content: space-between; flex-wrap: wrap; gap: 16px;
}
.footer-logo { display: flex; align-items: center; gap: 9px; text-decoration: none; }
.footer-logo-mark {
  width: 22px; height: 22px; border-radius: 6px;
  background: linear-gradient(140deg, var(--lavender), var(--mint));
}
.footer-logo span { font-size: 15px; font-weight: 700; color: var(--ink); letter-spacing: -0.4px; }
footer p { font-size: 13px; color: var(--ink-muted); }
.footer-links { display: flex; gap: 24px; }
.footer-links a { font-size: 13px; color: var(--ink-muted); text-decoration: none; transition: color 0.2s; }
.footer-links a:hover { color: var(--ink); }

@media (max-width: 768px) {
  nav { padding: 0 24px; }
  .nav-links { display: none; }
  footer { padding: 28px 24px; flex-direction: column; align-items: flex-start; }
}
</style>
