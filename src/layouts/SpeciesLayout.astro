---
import Base from './Base.astro';
import type { Especie } from '../data/especies';

interface Props {
  especie: Especie;
}

const { especie } = Astro.props;
---

<Base title={especie.nombre} description={especie.descripcionCorta} activeNav="especies">

  <!-- BREADCRUMB -->
  <div class="breadcrumb">
    <a href="/">Inicio</a>
    <span>›</span>
    <a href="/especies">Especies</a>
    <span>›</span>
    <span>{especie.nombre}</span>
  </div>

  <!-- HERO -->
  <div class="species-hero">
    <div class="species-hero-bg"></div>
    <div class="hero-orb orb-1"></div>
    <div class="hero-orb orb-2"></div>
    <div class="species-hero-content">
      <div class="species-label">Reproducción animal</div>
      <h1><em>{especie.nombre}</em></h1>
      <div class="species-scientific">{especie.nombreCientifico}</div>
      <p>{especie.descripcionCorta}</p>
      <div class="hero-actions">
        <a href="#anatomia" class="btn-primary">Comenzar</a>
      <a href={`/especies/comparativas?a=${especie.slug}`} class="btn-ghost-sp">Comparar especie</a>
      </div>
    </div>
  </div>

  <!-- STATS -->
  <div class="stats-strip">
    {especie.stats.map(s => (
      <div class="stat-item">
        <span class="stat-value">{s.valor}</span>
        <span class="stat-label">{s.etiqueta}</span>
        {s.nota && <span class="stat-note">{s.nota}</span>}
      </div>
    ))}
  </div>

  <!-- LAYOUT -->
  <div class="page-layout">
    <!-- TOC -->
    <aside class="toc-sidebar">
      <div class="toc-title">Contenido</div>
      <ul class="toc-list">
        <li><a href="#anatomia">Anatomía</a></li>
        <li><a href="#fisiologia">Fisiología</a></li>
        <li><a href="#ciclo-estral">Ciclo estral</a></li>
        <li><a href="#hormonas">Hormonas</a></li>
        <li><a href="#fertilizacion">Fertilización</a></li>
        <li><a href="#biotecnologias">Biotecnologías</a></li>
        <div class="toc-divider"></div>
        <li><a href="#comparativa">Comparativa</a></li>
        <li><a href="#glosario-local">Glosario</a></li>
        <li><a href="#recursos">Recursos</a></li>
        <li><a href="#quiz">Quiz</a></li>
      </ul>
    </aside>

    <!-- CONTENT -->
    <main class="content-main">
      <slot />
    </main>
  </div>

  <!-- SPECIES NAV -->
  <div class="species-nav">
    {especie.prev && (
      <a href={`/especies/${especie.prev.slug}`} class="species-nav-link prev">
        <div class="snl-icon">←</div>
        <div>
          <div class="snl-label">Especie anterior</div>
          <div class="snl-name">{especie.prev.nombre}</div>
        </div>
      </a>
    )}
    <div class="species-counter">
      {(() => {
        const idx = ['bovinos','porcinos','equinos','caninos','felinos','ovinos'].indexOf(especie.slug) + 1;
        return `${idx} DE 6 ESPECIES`;
      })()}
    </div>
    {especie.next && (
      <a href={`/especies/${especie.next.slug}`} class="species-nav-link next">
        <div>
          <div class="snl-label">Siguiente especie</div>
          <div class="snl-name">{especie.next.nombre}</div>
        </div>
        <div class="snl-icon">→</div>
      </a>
    )}
  </div>

</Base>

<style>
.species-hero {
  position: relative; padding: 72px 72px 60px;
  background: linear-gradient(160deg, #1a0b3b 0%, #2d1060 40%, #1a3d2e 100%);
  overflow: hidden; min-height: 440px; display: flex; align-items: center;
}
.species-hero-bg {
  position: absolute; inset: 0;
  background:
    radial-gradient(ellipse 60% 80% at 80% 50%, rgba(124,92,191,0.25) 0%, transparent 70%),
    radial-gradient(ellipse 40% 60% at 10% 80%, rgba(58,171,123,0.2) 0%, transparent 60%);
  pointer-events: none;
}
.hero-orb {
  position: absolute; border-radius: 50%; filter: blur(60px); pointer-events: none;
  animation: floatOrb 8s ease-in-out infinite;
}
.orb-1 { width: 320px; height: 320px; background: rgba(124,92,191,0.2); top: -60px; right: 15%; }
.orb-2 { width: 200px; height: 200px; background: rgba(58,171,123,0.18); bottom: -40px; right: 35%; animation-delay: -3s; }
@keyframes floatOrb {
  0%,100% { transform: translateY(0) scale(1); }
  50%     { transform: translateY(-20px) scale(1.04); }
}
.species-hero-content { position: relative; z-index: 2; max-width: 640px; }
.species-label {
  font-family: var(--mono); font-size: 11px; font-weight: 700;
  letter-spacing: 2px; text-transform: uppercase; color: var(--lavender-mid); margin-bottom: 20px;
}
.species-hero h1 {
  font-size: 64px; font-weight: 700; line-height: 1.0; letter-spacing: -2.5px;
  color: #fff; margin-bottom: 12px;
}
.species-hero h1 em {
  font-style: normal;
  background: linear-gradient(90deg, var(--lavender-mid), var(--mint-light));
  -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text;
}
.species-scientific {
  font-family: var(--mono); font-size: 14px; color: rgba(255,255,255,0.45);
  letter-spacing: 0.5px; margin-bottom: 28px; font-style: italic;
}
.species-hero p {
  font-size: 18px; line-height: 1.65; color: rgba(255,255,255,0.72); max-width: 520px; margin-bottom: 36px;
}
.hero-actions { display: flex; gap: 14px; align-items: center; flex-wrap: wrap; }
.btn-ghost-sp {
  padding: 12px 24px; border-radius: 4px; background: transparent;
  color: rgba(255,255,255,0.7); font-size: 15px; font-weight: 500;
  border: 1px solid rgba(255,255,255,0.2); text-decoration: none;
  transition: border-color 0.2s, color 0.2s;
}
.btn-ghost-sp:hover { border-color: var(--mint-light); color: var(--mint-light); }

.stats-strip {
  border-bottom: 1px solid var(--oat); background: var(--white);
  padding: 0 72px; display: flex;
}
.stat-item {
  flex: 1; padding: 28px 0; border-right: 1px solid var(--oat-light);
  display: flex; flex-direction: column; gap: 4px;
}
.stat-item:last-child { border-right: none; }
.stat-value { font-size: 28px; font-weight: 700; letter-spacing: -1px; color: var(--ink); }
.stat-label { font-size: 12px; font-weight: 500; color: var(--ink-muted); font-family: var(--mono); letter-spacing: 0.5px; text-transform: uppercase; }
.stat-note  { font-size: 11px; color: var(--ink-muted); }

.page-layout { display: flex; max-width: 1280px; margin: 0 auto; padding: 0 72px; gap: 48px; }
.toc-sidebar {
  width: 220px; flex-shrink: 0; position: sticky; top: 80px; height: fit-content; padding: 32px 0;
}
.toc-title {
  font-family: var(--mono); font-size: 10px; font-weight: 700;
  letter-spacing: 2px; text-transform: uppercase; color: var(--ink-muted); margin-bottom: 16px;
}
.toc-list { list-style: none; display: flex; flex-direction: column; gap: 2px; }
.toc-list li a {
  font-size: 14px; font-weight: 500; color: var(--ink-muted); text-decoration: none;
  padding: 6px 12px; border-radius: 8px; display: block;
  border-left: 2px solid transparent;
  transition: color 0.2s, border-color 0.2s, background 0.2s;
}
.toc-list li a:hover { color: var(--ink); background: var(--oat-light); }
.toc-list li a.active {
  color: var(--lavender); border-left-color: var(--lavender);
  background: rgba(124,92,191,0.06); font-weight: 600;
}
.toc-divider { height: 1px; background: var(--oat-light); margin: 12px 12px; }
.content-main { flex: 1; min-width: 0; padding: 48px 0 96px; }

.species-nav {
  border-top: 1px solid var(--oat); background: var(--white);
  padding: 28px 72px; display: flex; align-items: center; justify-content: space-between;
}
.species-counter {
  font-family: var(--mono); font-size: 11px; color: var(--ink-muted); letter-spacing: 1px;
}

@media (max-width: 1024px) {
  .toc-sidebar { display: none; }
  .species-hero { padding: 52px 32px; }
  .stats-strip, .page-layout, .species-nav { padding-left: 32px; padding-right: 32px; }
}
@media (max-width: 768px) {
  .species-hero h1 { font-size: 40px; }
  .species-nav { flex-direction: column; gap: 12px; }
}
</style>

<script>
// TOC active link tracking
const sections = document.querySelectorAll('section[id]');
const tocLinks = document.querySelectorAll('.toc-list a');
const obs = new IntersectionObserver(entries => {
  entries.forEach(e => {
    if (e.isIntersecting) {
      tocLinks.forEach(l => l.classList.remove('active'));
      const a = document.querySelector(`.toc-list a[href="#${e.target.id}"]`);
      if (a) a.classList.add('active');
    }
  });
}, { threshold: 0.4 });
sections.forEach(s => obs.observe(s));
</script>
