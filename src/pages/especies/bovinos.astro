        <div class="recurso-meta"><span>Lectura 15 min</span><span>Aplicación práctica</span></div>
      </div>
    </div>
  </div>
</section>

<!-- 10. QUIZ -->
<section id="quiz" class="content-section">
  <div class="section-label">10</div>
  <h2 class="section-title">Evalúa tu aprendizaje</h2>
  <div class="quiz-block reveal">
    <div class="quiz-progress">
      <div class="progress-bar-wrap"><div class="progress-bar-fill" style="width:20%"></div></div>
      <span class="progress-label">1 / 5 preguntas</span>
    </div>
    <div class="quiz-question" id="quiz-q">
      ¿Cuál es la hormona responsable de la luteólisis del cuerpo lúteo bovino al final del diestro?
    </div>
    <div class="quiz-options" id="quiz-opts">
      <div class="quiz-option" data-correct="false"><div class="opt-letter">A</div>Progesterona (P4)</div>
      <div class="quiz-option" data-correct="true"><div class="opt-letter">B</div>Prostaglandina F2α (PGF2α)</div>
      <div class="quiz-option" data-correct="false"><div class="opt-letter">C</div>Hormona luteinizante (LH)</div>
      <div class="quiz-option" data-correct="false"><div class="opt-letter">D</div>Estrógenos (E₂)</div>
    </div>
  </div>
</section>

</SpeciesLayout>

<style>
.content-section { margin-bottom: 72px; padding-bottom: 72px; border-bottom: 1px solid var(--oat-light); }
.content-section:last-child { border-bottom: none; }
.glosario-list { display: flex; flex-direction: column; }
.glosario-item { padding: 20px 0; border-bottom: 1px solid var(--oat-light); display: flex; gap: 32px; align-items: baseline; }
.glosario-item:last-child { border-bottom: none; }
.glosario-term { font-size: 17px; font-weight: 700; color: var(--lavender); min-width: 200px; flex-shrink: 0; }
.glosario-def  { font-size: 14px; line-height: 1.7; color: var(--ink-mid); }
@media (max-width: 768px) {
  .glosario-item { flex-direction: column; gap: 8px; }
  .glosario-term { min-width: unset; }
}
</style>

<script>
document.querySelectorAll('.quiz-option').forEach(opt => {
  opt.addEventListener('click', function(this: HTMLElement) {
    document.querySelectorAll('.quiz-option').forEach(o => o.classList.remove('correct', 'wrong'));
    const isCorrect = this.dataset.correct === 'true';
    this.classList.add(isCorrect ? 'correct' : 'wrong');
    if (!isCorrect) {
      const correct = document.querySelector('.quiz-option[data-correct="true"]');
      if (correct) correct.classList.add('correct');
    }
  });
});
</script>
